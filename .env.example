# Hermes Gateway configuration
# Copy to .env and fill in your API keys

# ── Required (at least one) ─────────────────────────────────────────

# Primary provider (recommended: DeepSeek — best thinking support)
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# ── Backup providers (optional) ─────────────────────────────────────
# KIMI_API_KEY=
# KIMI_MODEL=kimi-k2.6
# QWEN_API_KEY=
# QWEN_MODEL=qwen-plus
# GLM_API_KEY=
# GLM_MODEL=glm-5.1
# MINIMAX_API_KEY=
# MINIMAX_MODEL=minimax-m2.7-highspeed
# MIMO_API_KEY=
# MIMO_MODEL=mimo-v2.5-pro

# ── Custom OpenAI-compatible endpoints (optional) ────────────────────
# CUSTOM1_NAME=my-provider
# CUSTOM1_KEY=sk-xxx
# CUSTOM1_BASE_URL=https://api.example.com/anthropic
# CUSTOM1_MODEL=default

# ── Server ──────────────────────────────────────────────────────────
# GATEWAY_PORT=8080
# PROXY_API_KEY=optional-local-auth-token
