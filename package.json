{
  "name": "deepseek-claude-proxy",
  "version": "0.2.3",
  "type": "module",
  "description": "Minimal zero-dependency proxy from Anthropic Messages API to DeepSeek",
  "license": "MIT",
  "main": "./dist/proxy.js",
  "types": "./dist/proxy.d.ts",
  "bin": {
    "deepseek-claude-proxy": "dist/proxy.js"
  },
  "exports": {
    ".": {
      "types": "./dist/proxy.d.ts",
      "import": "./dist/proxy.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "dev": "tsx src/proxy.ts",
    "build": "tsc",
    "start": "node dist/proxy.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text"
  },
  "keywords": [
    "anthropic",
    "claude",
    "claude-code",
    "deepseek",
    "proxy",
    "sse"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
